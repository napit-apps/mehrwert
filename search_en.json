---
layout: null
permalink: /search_en.json
---
[
{% assign lang = site.lang | default: 'en' %}
{% for post in site.posts %}
  {
    "title": "{{ post.title | escape }}",
    "author": "{{ post.author | default: site.author | escape }}",
    "tags": "{{ post.tags | join: ", " | escape }}",
    "category": "{{ post.category | default: post.categories | join: ", " | escape }}",
    "url": "{{ site.baseurl }}{{ post.url }}",
    "date": "{{ post.date | date_to_string }}",
    "lang": "{{ post.lang | default: lang | default: 'en' }}",
    "excerpt": "{{ post.excerpt | strip_html | strip_newlines | replace: '\n', ' ' | replace: '\r', ' ' | escape }}",
    "content": "{{ post.content | strip_html | strip_newlines | replace: '\n', ' ' | replace: '\r', ' ' | escape }}"
  }{% unless forloop.last %},{% endunless %}
{% endfor %}
]